generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Event {
  id                    String    @id @default(uuid())
  event_code            String    @unique
  admin_pin_hash        String
  admin_pin_salt        String
  round_duration_seconds Int      @default(1800)
  llm_instructions      String?   @default("")
  round_state           String    @default("NOT_STARTED") // NOT_STARTED | ACTIVE | ENDED
  round_started_at      DateTime?
  round_ends_at         DateTime?
  round_ended_at        DateTime?
  created_at            DateTime  @default(now())
  updated_at            DateTime  @updatedAt

  admin_sessions AdminSession[]
}

model AdminSession {
  id        String   @id @default(uuid())
  event_id  String
  token_hash String
  expires_at DateTime
  created_at DateTime @default(now())

  event Event @relation(fields: [event_id], references: [id], onDelete: Cascade)
}
